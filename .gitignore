# ── Maven build output ────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── Node / frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.npm/
frontend/.pnp
frontend/.pnp.js

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep Dockerfiles and docker-compose tracked — only ignore runtime artifacts
.docker/

# ── Spring Boot / Java ────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
semgrep-env/
*.tar.gz
